{
  "name": "agentos-vscode",
  "displayName": "AgentOS",
  "description": "Cross-agent continuity layer — never lose context when switching AI coding agents",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:agentos/state.json"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentos.switch",
        "title": "AgentOS: Switch Agent",
        "icon": "$(sync)"
      },
      { "command": "agentos.snapshot", "title": "AgentOS: Snapshot" },
      { "command": "agentos.status", "title": "AgentOS: Status" },
      { "command": "agentos.checkpoint", "title": "AgentOS: Checkpoint" },
      { "command": "agentos.history", "title": "AgentOS: History" }
    ],
    "views": {
      "explorer": [{ "id": "agentosView", "name": "AgentOS" }]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "agentos.switch",
          "when": "view == agentosView && viewItem == activeAgent",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --outfile=dist/extension.js --external:vscode",
    "watch": "npm run build -- --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
